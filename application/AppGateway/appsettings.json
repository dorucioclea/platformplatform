{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "blob-storage": "UseDevelopmentStorage=true"
  },
  "AllowedHosts": "*",
  "Hostnames": {
    "App": "app.dev.localhost"
  },
  "ReverseProxy": {
    "Routes": {
      "favicon": {
        "ClusterId": "main-static",
        "Match": {
          "Path": "/favicon.ico"
        },
        "Metadata": {
          "HostnameKey": "*"
        },
        "Transforms": [
          {
            "ResponseHeader": "Cache-Control",
            "Set": "public, max-age=604800"
          },
          {
            "ResponseHeader": "Content-Type",
            "Set": "image/x-icon"
          }
        ]
      },
      "apple-touch-icon": {
        "ClusterId": "main-static",
        "Match": {
          "Path": "/apple-touch-icon.png"
        },
        "Metadata": {
          "HostnameKey": "*"
        },
        "Transforms": [
          {
            "ResponseHeader": "Cache-Control",
            "Set": "public, max-age=604800"
          }
        ]
      },
      "manifest": {
        "ClusterId": "main-static",
        "Match": {
          "Path": "/manifest.json"
        },
        "Metadata": {
          "HostnameKey": "*"
        },
        "Transforms": [
          {
            "ResponseHeader": "Cache-Control",
            "Set": "public, max-age=604800"
          },
          {
            "ResponseHeader": "Content-Type",
            "Set": "application/manifest+json"
          }
        ]
      },
      "robots": {
        "ClusterId": "main-static",
        "Match": {
          "Path": "/robots.txt"
        },
        "Metadata": {
          "HostnameKey": "*"
        },
        "Transforms": [
          {
            "ResponseHeader": "Cache-Control",
            "Set": "public, max-age=604800"
          },
          {
            "ResponseHeader": "Content-Type",
            "Set": "text/plain"
          }
        ]
      },
      "tracking": {
        "ClusterId": "account-api",
        "Match": {
          "Path": "/api/track"
        },
        "Metadata": {
          "HostnameKey": "*"
        }
      },
      "avatars": {
        "ClusterId": "account-storage",
        "Match": {
          "Path": "/avatars/{**catch-all}"
        },
        "Metadata": {
          "HostnameKey": "*"
        },
        "Transforms": [
          {
            "ResponseHeader": "Cache-Control",
            "Set": "public, max-age=2592000, immutable"
          }
        ]
      },
      "logos": {
        "ClusterId": "account-storage",
        "Match": {
          "Path": "/logos/{**catch-all}"
        },
        "Metadata": {
          "HostnameKey": "*"
        },
        "Transforms": [
          {
            "ResponseHeader": "Cache-Control",
            "Set": "public, max-age=2592000, immutable"
          }
        ]
      },
      "account-legal-documents": {
        "ClusterId": "account-static",
        "Match": {
          "Path": "/legal/documents/{**catch-all}"
        },
        "Metadata": {
          "HostnameKey": "*"
        },
        "Transforms": [
          {
            "PathPattern": "legal/documents/{**catch-all}"
          },
          {
            "ResponseHeader": "Content-Type",
            "Set": "text/markdown; charset=utf-8"
          },
          {
            "ResponseHeader": "Cache-Control",
            "Set": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      "account-api": {
        "ClusterId": "account-api",
        "Match": {
          "Path": "/api/account/{**catch-all}"
        },
        "Metadata": {
          "HostnameKey": "App"
        }
      },
      "account-federation": {
        "ClusterId": "account-static",
        "Match": {
          "Path": "/account/remoteEntry.js"
        },
        "Metadata": {
          "HostnameKey": "App"
        },
        "Transforms": [
          {
            "PathPattern": "/remoteEntry.js"
          }
        ]
      },
      "account-static": {
        "ClusterId": "account-static",
        "Match": {
          "Path": "/account/static/{**catch-all}"
        },
        "Metadata": {
          "HostnameKey": "App"
        },
        "Transforms": [
          {
            "PathPattern": "static/{**catch-all}"
          }
        ]
      },
      "account-hmr": {
        "ClusterId": "account-static",
        "Match": {
          "Path": "/account/{filename}.hot-update.{ext}"
        },
        "Metadata": {
          "HostnameKey": "App"
        },
        "Transforms": [
          {
            "PathPattern": "/{filename}.hot-update.{ext}"
          }
        ]
      },
      "main-static": {
        "ClusterId": "main-static",
        "Match": {
          "Path": "/static/{**catch-all}"
        },
        "Metadata": {
          "HostnameKey": "App"
        }
      },
      "main-hmr": {
        "ClusterId": "main-static",
        "Match": {
          "Path": "/{filename}.hot-update.{ext}"
        },
        "Metadata": {
          "HostnameKey": "App"
        }
      },
      "main": {
        "ClusterId": "main-api",
        "Match": {
          "Path": "/{**catch-all}"
        },
        "Metadata": {
          "HostnameKey": "App"
        }
      }
    },
    "Clusters": {
      "account-api": {
        "Destinations": {
          "destination": {
            "Address": "https://placeholder.invalid"
          }
        }
      },
      "account-static": {
        "Destinations": {
          "destination": {
            "Address": "https://placeholder.invalid"
          }
        }
      },
      "main-api": {
        "Destinations": {
          "destination": {
            "Address": "https://placeholder.invalid"
          }
        }
      },
      "main-static": {
        "Destinations": {
          "destination": {
            "Address": "https://placeholder.invalid"
          }
        }
      },
      "account-storage": {
        "Destinations": {
          "destination": {
            "Address": "https://placeholder.invalid"
          }
        }
      }
    }
  }
}
