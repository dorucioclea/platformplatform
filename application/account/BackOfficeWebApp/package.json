{
  "name": "account-back-office-webapp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run swagger && rsbuild build",
    "check": "oxfmt --check && oxlint",
    "dev": "rsbuild dev",
    "dev:setup": "npm run update-translations && npm run swagger",
    "format": "oxfmt && (oxlint --fix || true)",
    "lint": "oxlint --deny-warnings",
    "publish": "npm run build && mkdir -p ../Api/publish/BackOfficeWebApp/dist/ && rsync -r ./dist/ ../Api/publish/BackOfficeWebApp/dist/",
    "swagger": "openapi-typescript shared/lib/api/Account.Api_back-office.json -o shared/lib/api/api.generated.d.ts --properties-required-by-default -t --enum --alphabetize",
    "update-translations": "lingui extract --clean && lingui compile --typescript"
  },
  "devDependencies": {
    "@repo/build": "*",
    "@repo/config": "*",
    "@repo/infrastructure": "*",
    "@repo/ui": "*"
  }
}
