{
  "mcpServers": {
    "developer-cli": {
      "command": "dotnet",
      "args": ["run", "--project", "developer-cli", "mcp"]
    },
    "shadcn": {
      "command": "npx",
      "args": ["-y", "shadcn@latest", "mcp"]
    },
    "aspire": {
      "command": "aspire",
      "args": ["agent", "mcp"]
    }
  }
}